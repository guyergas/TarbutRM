# Copy this file to .env.dev and .env.prod and fill in real values.
# Never commit .env.dev or .env.prod to git.

# ---- Postgres ----
# Same password used for both dev and prod (same postgres instance on the VM)
POSTGRES_PASSWORD=changeme

# ---- App database connection ----
# Dev:  DATABASE_URL="postgresql://postgres:changeme@db:5432/tarbutrm_dev"
# Prod: DATABASE_URL="postgresql://postgres:changeme@db:5432/tarbutrm_prod"
DATABASE_URL=postgresql://postgres:changeme@db:5432/tarbutrm_dev

# ---- Auth.js ----
# Generate with: openssl rand -base64 32
# Must be different between dev and prod
AUTH_SECRET=replace-with-a-random-32-char-secret

# ---- App URL ----
# Dev:  NEXTAUTH_URL=http://<vm-ip>:3001
# Prod: NEXTAUTH_URL=http://<vm-ip>
NEXTAUTH_URL=http://localhost:3001

# ---- Seed (first deploy) ----
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

# ---- Misc ----
NEXT_TELEMETRY_DISABLED=1
