generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  STAFF
  ADMIN
}

enum OrderStatus {
  NEW
  IN_PROGRESS
  COMPLETED
}

enum TransactionType {
  ADMIN_CREDIT
  ADMIN_DEBIT
  CARD_TOPUP
}

enum MessageStatus {
  OPEN
  CLOSED
}

model User {
  id                   String                @id @default(cuid())
  firstName            String
  lastName             String
  email                String                @unique
  passwordHash         String
  role                 Role                  @default(USER)
  balance              Decimal               @default(0) @db.Decimal(10, 2)
  active               Boolean               @default(true)
  tutorialViewed       Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  phone                String?
  city                 String
  street               String?
  createdBy            String?
  sessions             Session[]
  menus                Menu[]                @relation("MenuCreatedBy")
  sections             Section[]             @relation("SectionCreatedBy")
  items                Item[]                @relation("ItemCreatedBy")
  stockHistoryChanges  ItemStockHistory[]    @relation("StockChangedBy")
  cartItems            CartItem[]            @relation("CartItems")
  orders               Order[]               @relation("OrderUser")
  orderStatusHistory   OrderStatusHistory[]  @relation("OrderStatusChangedBy")
}

model BudgetTransaction {
  id        String            @id @default(cuid())
  userId    String
  amount    Decimal           @db.Decimal(10, 2)
  note      String?
  type      TransactionType   @default(ADMIN_CREDIT)
  createdBy String
  createdAt DateTime          @default(now())

  @@index([userId])
}

model Menu {
  id        String    @id @default(cuid())
  name      String
  archived  Boolean   @default(false)
  position  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String
  creator   User      @relation("MenuCreatedBy", fields: [createdBy], references: [id])
  sections  Section[]
}

model Section {
  id        String   @id @default(cuid())
  menuId    String
  menu      Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  name      String
  archived  Boolean  @default(false)
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String
  creator   User     @relation("SectionCreatedBy", fields: [createdBy], references: [id])
  items     Item[]

  @@index([menuId])
}

model Item {
  id          String          @id @default(cuid())
  sectionId   String
  section     Section         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal         @db.Decimal(10, 2)
  inStock     Boolean         @default(true)
  position    Int
  archived    Boolean         @default(false)
  image       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String
  creator     User            @relation("ItemCreatedBy", fields: [createdBy], references: [id])
  stockHistory ItemStockHistory[]
  cartItems    CartItem[]      @relation("CartItems")
  orderItems   OrderItem[]     @relation("OrderItem")

  @@index([sectionId])
}

model ItemStockHistory {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  inStock   Boolean
  changedBy String
  changer   User     @relation("StockChangedBy", fields: [changedBy], references: [id])
  changedAt DateTime @default(now())

  @@index([itemId])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("CartItems", fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation("CartItems", fields: [itemId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, itemId])
  @@index([userId])
}

model Order {
  id            String          @id @default(cuid())
  orderNumber   Int             @unique @default(autoincrement())
  userId        String
  user          User            @relation("OrderUser", fields: [userId], references: [id], onDelete: Cascade)
  status        OrderStatus     @default(NEW)
  total         Decimal         @db.Decimal(10, 2)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation("OrderItem", fields: [itemId], references: [id])
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)

  @@index([orderId])
  @@index([itemId])
}

model OrderStatusHistory {
  id         String      @id @default(cuid())
  orderId    String
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String
  changer    User        @relation("OrderStatusChangedBy", fields: [changedBy], references: [id])
  changedAt  DateTime    @default(now())

  @@index([orderId])
}

// Auth.js required tables (managed by Prisma adapter)
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ContactMessage {
  id          String         @id @default(cuid())
  email       String
  name        String?
  title       String
  description String
  status      MessageStatus  @default(OPEN)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  closedAt    DateTime?

  @@index([status])
}
